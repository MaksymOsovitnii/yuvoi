<script lang="ts">
  export let variant: 'primary' | 'secondary' = 'primary';

  $: buttonClass = variant === 'primary'
    ? 'bg-blue-500 hover:bg-blue-600'
    : 'bg-gray-500 hover:bg-gray-600';
</script>

<button
