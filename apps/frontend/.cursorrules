<!-- src/modules/shuttle-booking/pages/ShuttleListPage.svelte -->
<script lang="ts">
  import { onMount } from 'svelte';
  import { shuttleBookingStore } from '../store';
  import ShuttleCard from '../components/ShuttleCard.svelte';
  import { Loader } from '$modules/common/components/Loader.svelte';

