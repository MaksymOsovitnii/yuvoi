```svelte
<!-- Preload on hover -->
<a href="/about" data-sveltekit-preload-data="hover">About</a>

<!-- Preload on viewport entry -->
<a href="/blog" data-sveltekit-preload-data="viewport">Blog</a>
```

## Error Handling

### Error Pages

```svelte
<!-- src/routes/+error.svelte -->
<script lang="ts">
  import { page } from '$app/stores';

  $: error = $page.error;
  $: status = $page.status;
</script>

<div class="error-container">
  <h1>{status}</h1>
  <p>{error?.message}</p>
  <a href="/">Go Home</a>
    </div>
```

### Throwing Errors

```typescript
import { error } from '@sveltejs/kit';

export const load: PageLoad = async ({ params }) => {
  const data = await fetchData(params.id);

  if (!data) {
    throw error(404, {
      message: 'Not found'
    });
  }

  return { data };
};
```

## Hooks (Server-Side Middleware)

### Server Hooks

```typescript
// src/hooks.server.ts
import type { Handle } from '@sveltejs/kit';

export const handle: Handle = async ({ event, resolve }) => {
  // Authentication check
  const sessionId = event.cookies.get('session');

  if (sessionId) {
    const user = await getUserFromSession(sessionId);
    event.locals.user = user;
  }

  // Continue to the route
  const response = await resolve(event);

  // Modify response headers if needed
  response.headers.set('x-custom-header', 'value');

  return response;
};
```

### Client Hooks

```typescript
// src/hooks.client.ts
import type { HandleClientError } from '@sveltejs/kit';

export const handleError: HandleClientError = ({ error, event }) => {
  console.error('Client error:', error);

  return {
    message: 'An error occurred',
    code: 'UNKNOWN'
  };
};
```

## Environment Variables

### Accessing Environment Variables

```typescript
// Public variables (exposed to client) - prefix with PUBLIC_
import { PUBLIC_API_URL } from '$env/static/public';
import { PUBLIC_APP_NAME } from '$env/dynamic/public';

// Private variables (server-only) - no prefix
import { DATABASE_URL } from '$env/static/private';
import { SECRET_API_KEY } from '$env/dynamic/private';
```

### .env File

```bash
# Public (exposed to browser)
PUBLIC_API_URL=https://api.example.com
PUBLIC_APP_NAME=My App

# Private (server-only)
DATABASE_URL=postgresql://...
SECRET_API_KEY=secret123
```

## Code Quality Standards

### Component Best Practices

1. **Keep components small** - under 200 lines ideally
2. **Single responsibility** - each component does one thing well
3. **Props over slots** - prefer explicit props for simple cases
4. **Slots for composition** - use slots for flexible content
5. **Export event types** - make event contracts clear

### DRY Principle

- Extract repeated markup into components
- Create utility functions for common logic
- Use stores for shared state
- Centralize API calls
- Reuse TypeScript types

### Naming Consistency

- Be descriptive and clear
- Use established patterns
- Follow SvelteKit conventions
- Maintain consistency across codebase

## Performance Optimization

### Code Splitting

- SvelteKit automatically code-splits routes
- Use dynamic imports for heavy components:

```svelte
<script lang="ts">
  import { onMount } from 'svelte';

  let HeavyComponent;

  onMount(async () => {
    const module = await import('$lib/components/HeavyComponent.svelte');
    HeavyComponent = module.default;
  });
</script>

{#if HeavyComponent}
  <svelte:component this={HeavyComponent} />
{/if}
```

### Image Optimization

```svelte
<img
  src="/images/photo.jpg"
  alt="Description"
  loading="lazy"
  decoding="async"
  width="800"
  height="600"
/>
```

### Reactive Performance

```svelte
<script lang="ts">
  import { onMount, beforeUpdate, afterUpdate } from 'svelte';

  let items = [];

  // Avoid expensive computations on every change
  $: sorted = items.slice().sort(); // ❌ Runs every time items changes

  // Better: Memoize expensive operations
  let cachedSorted = [];
  $: if (items.length !== cachedSorted.length) {
    cachedSorted = items.slice().sort();
  }
</script>
```

