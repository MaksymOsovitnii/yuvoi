```bash
# Development
npm run dev              # Start dev server
npm run check            # Type check
npm run lint             # Lint code
npm run format           # Format code

# Module creation helper
mkdir -p src/modules/new-feature/{pages,components,store,types,consts,utils}
touch src/modules/new-feature/store/index.ts
touch src/modules/new-feature/types/index.ts
touch src/modules/new-feature/consts/index.ts
```
